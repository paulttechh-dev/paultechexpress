{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Client, Motoboy, or Admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "motoboy", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a collection/delivery request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "motoboyId": { "type": "string" },
        "motoboyName": { "type": "string" },
        "address": { "type": "string" },
        "problem": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["waiting", "accepted", "on_route", "collected", "in_maintenance", "delivered", "cancelled"] 
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "clientName", "address", "problem", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Service orders"
    }
  }
}
